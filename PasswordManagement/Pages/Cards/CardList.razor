@page "/"
@page "/cardlist"
@layout MainLayout
@attribute [Authorize(Roles = "Admin")]

<div class="accounts-page">
    @if (IsLoading)
    {
        <div class="page-heading">
            <MudText Typo="Typo.h4">Accounts</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading your saved accounts…</MudText>
        </div>

        <MudPaper Class="loading-surface pa-4" Elevation="0">
            @for (var index = 0; index < 6; index++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="52px" Class="mb-2" />
            }
        </MudPaper>
    }
    else if (!string.IsNullOrEmpty(LoadErrorMessage))
    {
        <div class="page-heading">
            <MudText Typo="Typo.h4">Accounts</MudText>
        </div>

        <MudPaper Class="state-surface pa-8" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-3">Accounts could not be loaded</MudText>
            <MudText Color="Color.Secondary" Class="mt-1 mb-4">@LoadErrorMessage</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadAccountsAsync">
                Retry
            </MudButton>
        </MudPaper>
    }
    else
    {
        <div class="page-header">
            <div>
                <MudText Typo="Typo.h4">Accounts</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @Cards.Count @(Cards.Count == 1 ? "saved account" : "saved accounts")
                </MudText>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="SendtoAddCard">
                Add account
            </MudButton>
        </div>

        @if (Cards.Count == 0)
        {
            <MudPaper Class="state-surface pa-8" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.AccountBox" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-3">No accounts yet</MudText>
                <MudText Color="Color.Secondary" Class="mt-1 mb-4">
                    Add your first account to begin managing credentials.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="SendtoAddCard">
                    Add account
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="accounts-surface" Elevation="1">
                <div class="table-toolbar">
                    <div class="search-wrapper">
                        <MudTextField @bind-Value="SearchValue"
                                      Label="Search accounts"
                                      Placeholder="Name, user code, email, or website"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true"
                                      DebounceInterval="300"
                                      Clearable
                                      aria-label="Search accounts" />
                    </div>
                </div>

                <MudTable Items="Cards"
                          Breakpoint="Breakpoint.Md"
                          Hover="true"
                          RowsPerPage="10"
                          Filter="new Func<MstCard, bool>(FilterFuncCards)">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<MstCard, object>(account => account.CardName)">Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<MstCard, object>(account => account.Alias)">Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<MstCard, object>(account => account.UserCode)">User code</MudTableSortLabel></MudTh>
                        <MudTh>Password</MudTh>
                        <MudTh Class="email-column"><MudTableSortLabel SortBy="new Func<MstCard, object>(account => account.Email)">Email</MudTableSortLabel></MudTh>
                        <MudTh Class="actions-column">Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="Type">@context.CardName</MudTd>
                        <MudTd DataLabel="Name">@context.Alias</MudTd>
                        <MudTd DataLabel="User code">
                            <div class="credential-cell">
                                <MudTooltip Text="Copy user code">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Variant="Variant.Text"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   OnClick="@(() => CopyUser(context.UserCode))"
                                                   aria-label="@($"Copy user code for {context.Alias}")" />
                                </MudTooltip>
                                <span class="credential-value">@context.UserCode</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Password">
                            <div class="credential-cell">
                                <MudTooltip Text="@(IsPasswordVisible(context.Id) ? "Hide password" : "Show password")">
                                    <MudIconButton Icon="@(IsPasswordVisible(context.Id) ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                   Variant="Variant.Text"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   OnClick="@(() => TogglePasswordVisibility(context.Id))"
                                                   aria-label="@($"{(IsPasswordVisible(context.Id) ? "Hide" : "Show")} password for {context.Alias}")" />
                                </MudTooltip>
                                <MudTooltip Text="Copy password">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Variant="Variant.Text"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   OnClick="@(() => CopyPassword(context.Password))"
                                                   aria-label="@($"Copy password for {context.Alias}")" />
                                </MudTooltip>
                                <span class="credential-value password-value">
                                    @(IsPasswordVisible(context.Id) ? context.Password : "••••••••")
                                </span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Email" Class="email-column">@context.Email</MudTd>
                        <MudTd DataLabel="Actions" Class="actions-column">
                            <div class="desktop-actions">
                                <MudTooltip Text="Edit account">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="(() => OpenDialogEdit(context.Id))"
                                                   aria-label="@($"Edit {context.Alias}")" />
                                </MudTooltip>
                                <MudTooltip Text="Delete account">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Variant="Variant.Text"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="(() => OpenDialogDelete(context))"
                                                   aria-label="@($"Delete {context.Alias}")" />
                                </MudTooltip>
                            </div>

                            <div class="mobile-actions">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                         Size="Size.Small"
                                         aria-label="@($"Actions for {context.Alias}")">
                                    <MudMenuItem OnClick="(() => OpenDialogEdit(context.Id))">
                                        Edit
                                    </MudMenuItem>
                                    <MudMenuItem OnClick="(() => OpenDialogDelete(context))">
                                        Delete
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        </MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="filtered-empty-state">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Class="mt-2">No accounts match your search</MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearSearch" Class="mt-1">
                                Clear search
                            </MudButton>
                        </div>
                    </NoRecordsContent>

                    <PagerContent>
                        <MudTablePager HorizontalAlignment="HorizontalAlignment.Right"
                                       RowsPerPageString="Rows per page:"
                                       PageSizeOptions="@PageSizeOptions" />
                    </PagerContent>
                </MudTable>
            </MudPaper>
        }
    }
</div>
