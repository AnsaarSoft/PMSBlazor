@page "/editcard"
@page "/editcard/{Id:int}"
@layout MainLayout
@attribute [Authorize(Roles = "Admin")]

<NavigationLock ConfirmExternalNavigation="@HasUnsavedChanges"
                OnBeforeInternalNavigation="ConfirmInternalNavigation" />

<div class="edit-account-page">
    @if (IsLoading)
    {
        <div class="page-heading">
            <MudText Typo="Typo.h4">Edit account</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading account details…</MudText>
        </div>

        <MudPaper Class="loading-surface pa-4" Elevation="0">
            @for (var index = 0; index < 7; index++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" Class="mb-3" />
            }
        </MudPaper>
    }
    else if (!string.IsNullOrEmpty(LoadErrorMessage))
    {
        <MudBreadcrumbs Items="BreadcrumbItems" />

        <MudPaper Class="state-surface pa-8" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-3">Account could not be loaded</MudText>
            <MudText Color="Color.Secondary" Class="mt-1 mb-4">@LoadErrorMessage</MudText>
            <div class="state-actions">
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/cardlist">
                    Back to accounts
                </MudButton>
                @if (Id > 0)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadAccountAsync">
                        Retry
                    </MudButton>
                }
            </div>
        </MudPaper>
    }
    else
    {
        <MudBreadcrumbs Items="BreadcrumbItems" />

        <div class="page-heading">
            <MudText Typo="Typo.h4">Edit account</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Update the details and credentials for @oModel.Alias.
            </MudText>
        </div>

        <EditForm EditContext="@FormContext" OnValidSubmit="SaveCard" OnInvalidSubmit="HandleInvalidSubmit">
            <DataAnnotationsValidator />

            <AccountFormFields @ref="AccountForm"
                               Model="oModel"
                               SearchAccountTypes="SearchAccountTypes"
                               IsSaving="IsSaving"
                               IsLoadingFormData="IsLoadingFormData"
                               IsGenerating="IsGenerating"
                               IsPasswordVisible="IsPasswordVisible"
                               CanGeneratePassword="@(PasswordSettings is not null)"
                               PasswordSettingsDescription="PasswordSettingsDescription"
                               CredentialsDescription="Update the sign-in information for this account."
                               SubmitText="Save changes"
                               SubmittingText="Saving changes…"
                               SubmitIcon="@Icons.Material.Filled.Save"
                               TogglePasswordVisibility="TogglePasswordVisibility"
                               GeneratePassword="GeneratePassword"
                               CopyPassword="CopyPassword"
                               Cancel="CancelCard" />
        </EditForm>
    }
</div>
